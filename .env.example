APP_NAME="Recensement & Cartographie Urbaine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Log Configuration (Remplacement du MailSender et d'Audits système)
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de Données (Support des UUIDs et intégrité référentielle en cascade)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=doda5678_db_res
DB_USERNAME=doda5678_res
DB_PASSWORD=",@@Druide2020"

# Drivers de Sessions, Caches et Queues (Sélection optimale de performance)
# Utilisez database pour conserver un traçage optimal des sessions actives d'agents
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache : requis pour les statistiques à haute vitesse du DashboardController
CACHE_STORE=database
CACHE_PREFIX=rec_

# Queue : synchrone par défaut (synchrone/database pour l'envoi de mails ultérieurs)
QUEUE_CONNECTION=sync

# Simulation de l'envoi d'e-mails dans les logs locaux (Similaire à email_delivery.log)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@commune-recensement.gov"
MAIL_FROM_NAME="${APP_NAME}"

# Stockage et Fichiers (Spatie Media Library)
FILESYSTEM_DISK=public

# Configuration Sanctum (API de collecte mobile sécurisée hors-ligne)
SANCTUM_STATEFUL_DOMAINS=localhost

# Configuration CORS (Requis pour l'interconnexion mobile/web externe sur o2switch)
# Séparez les domaines autorisés par des virgules sans espaces (Ex: https://recensement-commune.fr,https://mobile.recensement-commune.fr)
CORS_ALLOWED_ORIGINS=*

